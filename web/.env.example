DATABASE_URL="postgresql://postgres@127.0.0.1:5432/fliplocker_staging"
APP_URL="http://localhost:3000"
SESSION_SECRET="replace-me"

# Email — set RESEND_API_KEY to send real mail; otherwise mail is captured in the dev outbox
RESEND_API_KEY=""
EMAIL_FROM="FlipLocker <deals@fliplocker.app>"

# PayPal Complete Payments (multiparty) — SANDBOX. Leave blank to run the built-in simulator.
PAYPAL_MODE="simulator"           # simulator | sandbox | live
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MERCHANT_ID=""             # platform (FlipLocker) merchant id
PAYPAL_BN_CODE=""
PAYPAL_WEBHOOK_ID=""

# Media storage — set S3_* to use S3 presigned uploads; otherwise local dev storage
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
