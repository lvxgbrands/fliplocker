generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Users & auth ----------

enum Role {
  SELLER
  BUYER
  FACILITATOR
  ADMIN
}

enum PlanTier {
  FREE
  PRO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  phone         String? // optional, for SMS alerts (A-9)
  role          Role      @default(SELLER)
  plan          PlanTier  @default(FREE)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions          Session[]
  tokens            AuthToken[]
  sellerDeals       Deal[]          @relation("SellerDeals")
  buyerDeals        Deal[]          @relation("BuyerDeals")
  hubInspections    HubInspection[] @relation("FacilitatorInspections")
  offers            Offer[]         @relation("SellerOffers")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

enum AuthTokenKind {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model AuthToken {
  id        String        @id @default(cuid())
  token     String        @unique
  kind      AuthTokenKind
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_tokens")
}

// ---------- Deals ----------

enum DealStatus {
  DRAFT
  CREATED
  BUYER_NOTIFIED
  ACCEPTED
  PAID
  AWAITING_SELLER_SHIPMENT
  IN_TRANSIT_TO_HUB
  RECEIVED_AT_HUB
  VERIFIED
  REPACKED
  IN_TRANSIT_TO_BUYER
  DELIVERED_SIGNED
  FUNDS_RELEASED
  COMPLETE
  DECLINED
  CANCELLED
  REFUNDED
  FLAGGED
}

model Deal {
  id          String     @id @default(cuid())
  shortCode   String     @unique // human-friendly reference, e.g. FL-7G2K9Q
  sellerId    String
  buyerEmail  String
  buyerId     String? // null until the buyer claims the invite
  inviteToken String     @unique
  status      DealStatus @default(CREATED)

  // Card details (NOTE: no comp/market value column, fee is f(sale_price) only)
  sport          String
  cardYear       Int
  playerName     String
  gradingCompany String
  grade          String? // e.g. "PSA 3", display-only, shown on the slab plate
  certNumber     String
  description    String?

  // Money (all cents). Line items snapshotted at creation from FeeConfig.
  salePriceCents     Int
  feeTotalCents      Int // total service fee
  feeBuyerCents      Int // buyer's share per who-pays config
  feeSellerCents     Int // seller's share per who-pays config
  shippingCents      Int // flat outbound shipping & signature line (buyer pays)
  insuranceCents     Int
  taxCents           Int
  buyerTotalCents    Int // what the buyer is charged at checkout
  sellerPayoutCents  Int // what the seller receives on release
  feeConfigSnapshot  Json // the config rows used, for the transaction record

  // Terms of Service acknowledgment, required before a shipping label is generated.
  tosAcceptedAt DateTime?

  // Lifecycle timestamps + timer deadlines (all set as the deal advances).
  acceptedAt      DateTime?
  declinedAt      DateTime?
  paidAt          DateTime?
  shipDeadlineAt  DateTime? // 72h ship window from Leg 1 label
  receivedAt      DateTime? // arrived at hub
  verifiedAt      DateTime?
  deliveredAt     DateTime? // signature-confirmed delivery to buyer
  reviewDeadlineAt DateTime? // 48h buyer review window from delivery
  fundsReleasedAt DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?
  flagReason      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Set when this deal was spawned from an open offer link (first-buyer-to-pay).
  offerId String?

  seller     User            @relation("SellerDeals", fields: [sellerId], references: [id])
  buyer      User?           @relation("BuyerDeals", fields: [buyerId], references: [id])
  offer      Offer?          @relation(fields: [offerId], references: [id])
  media      DealMedia[]
  payments   Payment[]
  shipments  Shipment[]
  events     DealEvent[]
  inspection HubInspection?

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([offerId])
  @@map("deals")
}

enum MediaKind {
  FRONT_PHOTO
  REAR_PHOTO
  HUB_VIDEO
  HUB_PHOTO_1
  HUB_PHOTO_2
}

model DealMedia {
  id          String    @id @default(cuid())
  dealId      String
  kind        MediaKind
  storageKey  String
  contentType String
  // Set for hub video/photos: auto-purge 30 days after confirmed delivery (A-9).
  purgeAfter  DateTime?
  purgedAt    DateTime?
  createdAt   DateTime  @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, kind])
  @@map("deal_media")
}

// ---------- Hub documentation (facilitator) ----------

enum InspectionResult {
  PENDING
  PASS
  FAIL
}

model HubInspection {
  id              String           @id @default(cuid())
  dealId          String           @unique
  facilitatorId   String?
  tamperSealSerial String?
  result          InspectionResult @default(PENDING)
  notes           String?
  checkedInAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  deal        Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  facilitator User? @relation("FacilitatorInspections", fields: [facilitatorId], references: [id])

  @@map("hub_inspections")
}

// ---------- Payments ----------

enum PaymentState {
  CREATED
  APPROVED
  CAPTURED
  VOIDED
  REFUNDED
  FAILED
}

model Payment {
  id              String       @id @default(cuid())
  dealId          String
  provider        String       @default("PAYPAL") // PAYPAL | PAYPAL_SIM
  paypalOrderId   String       @unique
  authorizationId String?
  captureId       String?
  refundId        String?
  disbursedAt     DateTime? // delayed disbursement released to seller (multiparty)
  refundedAt      DateTime?
  state           PaymentState @default(CREATED)
  // Amount breakdown (cents) as sent to the processor
  grossCents      Int // buyer total charged
  platformFeeCents Int // FlipLocker's service fee (the ONLY money routed to the platform)
  sellerNetCents  Int // held by the processor for the seller
  currency        String       @default("USD")
  rawCreate       Json?
  rawCapture      Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("payments")
}

// ---------- Shipping (built out in Week 3; schema landed now) ----------

enum ShipmentLeg {
  TO_HUB
  TO_BUYER
}

model Shipment {
  id                String      @id @default(cuid())
  dealId            String
  leg               ShipmentLeg
  carrier           String      @default("USPS")
  service           String? // e.g. "USPS Ground Advantage", "Priority + Signature"
  trackingNumber    String?
  labelUrl          String?
  labelChargeCents  Int         @default(0)
  signatureRequired Boolean     @default(false)
  status            String      @default("PENDING") // PENDING|LABEL_CREATED|IN_TRANSIT|DELIVERED
  lastScanAt        DateTime?
  deliveredAt       DateTime?
  signedBy          String?
  provider          String      @default("SIM") // SIM | EASYPOST
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("shipments")
}

// ---------- Events (append-only transparency timeline) ----------

model DealEvent {
  id        String   @id @default(cuid())
  dealId    String
  type      String // e.g. DEAL_CREATED, BUYER_INVITED, INVITE_CLAIMED, ACCEPTED, PAYMENT_CAPTURED, ...
  actor     String // system | seller | buyer | facilitator | admin
  message   String // human-readable line shown on the timeline
  payload   Json?
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@map("deal_events")
}

// ---------- Fee & checkout configuration (Admin-editable; NO hardcoded numbers) ----------
// Fee model per plan tier: below crossoverPriceCents the fee is flat floorCents;
// at/above it the fee is percentBps of the sale price. Fee depends on sale price ONLY.

enum FeePayer {
  BUYER
  SELLER
  SPLIT
}

model FeeConfig {
  id                 String   @id @default(cuid())
  plan               PlanTier @unique
  floorCents         Int // flat fee below the crossover price
  percentBps         Int // basis points applied at/above the crossover
  crossoverPriceCents Int // sale price at which % takes over from the floor
  whoPays            FeePayer
  active             Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  @@map("fee_config")
}

// Singleton row of platform-wide checkout settings (id fixed to "default").
model CheckoutConfig {
  id                     String   @id @default("default")
  minSalePriceCents      Int // minimum allowed sale price
  outboundShippingCents  Int // flat outbound shipping & signature line, charged to buyer
  insuranceEnabled       Boolean  @default(true)
  insuranceCentsPer100   Int // pass-through declared-value coverage, per $100 of sale price
  taxEnabled             Boolean  @default(false)
  defaultTaxBps          Int      @default(0) // used when no per-state row matches
  // Leg 1 label charge billed to the seller (configurable, A-3).
  sellerLabelChargeCents Int      @default(0)
  // Hub ship-to address (client-provided at kickoff).
  hubName                String   @default("FlipLocker Documentation Hub")
  hubStreet              String   @default("000 Placeholder St")
  hubCity                String   @default("Austin")
  hubState               String   @default("TX")
  hubZip                 String   @default("78701")
  // Timer windows (hours).
  shipTimerHours         Int      @default(72)
  reviewWindowHours      Int      @default(48)
  mediaPurgeDays         Int      @default(30)
  // Open offer links: how long the first buyer's exclusive checkout hold lasts
  // before the offer re-opens to the waitlist (minutes).
  offerHoldMinutes       Int      @default(30)
  updatedAt              DateTime @updatedAt

  taxRates TaxRate[]

  @@map("checkout_config")
}

model TaxRate {
  id        String @id @default(cuid())
  configId  String
  state     String // two-letter delivery state
  rateBps   Int
  active    Boolean @default(true)

  config CheckoutConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, state])
  @@map("tax_rates")
}

// ---------- Dev outboxes (capture transactional mail/SMS when no provider key) ----------

model EmailOutbox {
  id        String   @id @default(cuid())
  toEmail   String
  subject   String
  html      String
  provider  String // resend | dev-outbox
  dealId    String?
  sentAt    DateTime @default(now())

  @@index([sentAt])
  @@map("email_outbox")
}

model SmsOutbox {
  id        String   @id @default(cuid())
  toPhone   String
  body      String
  provider  String // twilio | dev-outbox
  dealId    String?
  sentAt    DateTime @default(now())

  @@index([sentAt])
  @@map("sms_outbox")
}

// ---------- Newsletter (marketing email capture; adapter/simulator pattern) ----------
// Simulator mode (default) captures subscribers here. Real mode also adds them to
// a Resend audience when RESEND_API_KEY + RESEND_AUDIENCE_ID are set.

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("footer") // footer | contact | insights
  status    String   @default("subscribed") // subscribed | unsubscribed
  provider  String   @default("dev-outbox") // resend | dev-outbox
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("newsletter_subscribers")
}

// ---------- Uploaded media bytes (local/simulator storage mode) ----------
// When no S3/blob store is configured, uploaded files (card photos, hub
// photos/videos) are stored here in Postgres instead of on disk, so uploads
// work on a read-only serverless filesystem. Served via /api/media (signed).
model UploadBlob {
  key       String   @id
  bytes     Bytes
  createdAt DateTime @default(now())

  @@map("upload_blobs")
}

// ---------- Open offer links (Phase 2) ----------
// A seller posts a public, single-use offer for a card at a fixed price and
// shares one link. The first buyer to reserve and pay wins: the reservation is
// an exclusive checkout hold, and a paid Deal is spawned on capture. Other
// interested buyers join the waitlist and are re-invited if the hold lapses or
// the winning deal later falls through.

enum OfferStatus {
  OPEN // available; first buyer to reserve + pay wins
  RESERVED // one buyer holds an exclusive checkout window
  CLAIMED // sold; a paid Deal exists
  CANCELLED // withdrawn by the seller (or expired)
}

model Offer {
  id        String      @id @default(cuid())
  linkToken String      @unique // public, unguessable share link
  shortCode String      @unique // human-friendly reference, e.g. OF-7G2K9Q
  sellerId  String
  status    OfferStatus @default(OPEN)

  // Card details (fee is f(sale_price) only, mirrors Deal, no comp/market value).
  sport          String
  cardYear       Int
  playerName     String
  gradingCompany String
  grade          String? // e.g. "PSA 3", display-only
  certNumber     String
  description    String?

  salePriceCents Int

  // Optional listing expiry (a listing can be time-boxed).
  expiresAt DateTime?

  // Exclusive checkout hold: the first buyer to reserve gets a window to pay.
  reservedById  String?
  reservedAt    DateTime?
  reservedUntil DateTime?
  pendingDealId String? // in-flight deal for the current reservation

  // Claim (won): the buyer who paid first + the deal that carried the payment.
  claimedById   String?
  claimedDealId String?
  claimedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller   User            @relation("SellerOffers", fields: [sellerId], references: [id])
  deals    Deal[]
  media    OfferMedia[]
  waitlist OfferWaitlist[]
  events   OfferEvent[]

  @@index([sellerId])
  @@index([status])
  @@map("offers")
}

model OfferMedia {
  id          String    @id @default(cuid())
  offerId     String
  kind        MediaKind // FRONT_PHOTO / REAR_PHOTO used for offers
  storageKey  String
  contentType String
  createdAt   DateTime  @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, kind])
  @@map("offer_media")
}

model OfferWaitlist {
  id         String    @id @default(cuid())
  offerId    String
  email      String
  name       String?
  userId     String? // set when a signed-in buyer joins
  notifiedAt DateTime? // last time this address was invited back to the offer
  createdAt  DateTime  @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, email])
  @@index([offerId])
  @@map("offer_waitlist")
}

// Append-only transparency timeline for an offer (powers the public trust page).
model OfferEvent {
  id        String   @id @default(cuid())
  offerId   String
  type      String
  actor     String // system | seller | buyer
  message   String
  payload   Json?
  createdAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, createdAt])
  @@map("offer_events")
}
